# ============================================================
# VulnArena — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# ============================================================

# ── Domain / TLS (this host = the API only) ──
# Hybrid deploy: the SvelteKit frontend is hosted on Vercel (vulnarena.com).
# This server runs ONLY the Go API, served at api.vulnarena.com.
DOMAIN=api.vulnarena.com
# Email Let's Encrypt uses for renewal notices and account recovery
CERTBOT_EMAIL=ops@vulnarena.com
# Set to 1 to issue a staging cert (avoids rate limits while testing)
CERTBOT_STAGING=0
# api.vulnarena.com is a subdomain with no "www." sibling — keep this 0 so the
# cert isn't also requested for www.api.vulnarena.com (which would fail ACME).
INCLUDE_WWW=0

# CORS — comma-separated list of origins allowed to call the Go API. These are
# the Vercel frontend's public origin(s), NOT this API host.
ALLOWED_ORIGINS=https://vulnarena.com,https://www.vulnarena.com

# NOTE: the frontend's PUBLIC_API_URL is configured in the VERCEL project's
# environment variables (not in this file), and must point at this API host:
#   PUBLIC_API_URL=https://api.vulnarena.com/api/v1

# ── PostgreSQL (Neon) ──
# Hosted on Neon. Use the -pooler endpoint (transaction-mode pgbouncer)
# for the application; the Go API auto-detects "-pooler." in the hostname
# and switches pgx to cache_describe mode so prepared statements don't
# break under the pooler.
#
# Format:
#   postgresql://USER:PASS@ep-XXX-pooler.<region>.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://USER:PASS@ep-XXX-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# NOTE: run migrations against the Neon DIRECT (non-pooler) endpoint — drop the
# "-pooler" from the host — while the running app uses the pooler endpoint above.
#
# The compose `migrate` service uses MIGRATE_DATABASE_URL when set (point it at
# the Neon DIRECT endpoint), and falls back to DATABASE_URL when empty. Setting
# it avoids golang-migrate advisory-lock stalls over Neon's pgbouncer pooler.
MIGRATE_DATABASE_URL=postgresql://USER:PASS@ep-XXX.<region>.aws.neon.tech/neondb?sslmode=require

# Connection-pool tuning for the Go API (pgxpool).
# Defaults are tuned for Neon's pooler — keep MaxConns small; pgbouncer
# fans backend connections out across many client checkouts and over-
# pooling on the client just creates contention.
DB_MAX_CONNS=15
DB_MIN_CONNS=2

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_64_CHAR_HEX_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Anthropic (semantic evaluator) ──
# Leave empty to fall back to keyword evaluator.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Discord (optional first-blood / achievement webhook) ──
DISCORD_WEBHOOK_URL=

# ── Nginx host ports ──
HTTP_PORT=80
HTTPS_PORT=443
