# ============================================================
# VulnArena — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# ============================================================

# PostgreSQL
POSTGRES_USER=vulnarena
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=vulnarena

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (use: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_64_CHAR_HEX_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Anthropic API (enables AI-powered semantic evaluation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=

# Frontend origin (used by SvelteKit CSRF protection)
ORIGIN=https://yourdomain.com

# Nginx listen port on the host
HTTP_PORT=80
