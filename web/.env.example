# ============================================================
# VulnArena Web — Frontend Environment Variables
# Copy to .env for local development.
# ============================================================
#
# PUBLIC_API_URL: the base URL the SvelteKit app uses to reach the Go API.
#
# - Production: leave UNSET. The app defaults to "/api/v1" (relative), which
#   nginx routes to the api service. Same origin → no CORS, no extra config.
# - Local dev: set this to the dev API URL with /api/v1 suffix so fetch calls
#   resolve to the Go server running on :8080.
#
PUBLIC_API_URL=http://localhost:8080/api/v1
