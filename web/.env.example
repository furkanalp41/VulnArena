# ============================================================
# VulnArena Web — Frontend Environment Variables
# Copy to .env for local development.
# ============================================================
#
# PUBLIC_API_URL: the base URL the SvelteKit app uses to reach the Go API.
#
# - Production (Vercel): set this in the Vercel project's Environment Variables
#   to the ABSOLUTE API host. Both REST and the WebSocket URL are derived from
#   it, so it must be the full origin:
#     PUBLIC_API_URL=https://api.vulnarena.com/api/v1
#   The Go API allows this cross-origin frontend via ALLOWED_ORIGINS, and auth
#   is a Bearer token (localStorage), so no cookie/CORS-credential setup needed.
# - Local dev: set this to the dev API URL with /api/v1 suffix so fetch calls
#   resolve to the Go server running on :8080.
#
PUBLIC_API_URL=http://localhost:8080/api/v1
