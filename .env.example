# Server
PORT=8080
ENV=development

# PostgreSQL
DATABASE_URL=postgres://vulnarena:vulnarena_secret@localhost:5432/vulnarena?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Anthropic API (enables AI-powered semantic evaluation)
# Leave ANTHROPIC_API_KEY empty to use keyword-based fallback evaluator
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Discord Webhook (optional — enables First Blood & Achievement announcements)
DISCORD_WEBHOOK_URL=
